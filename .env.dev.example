# Local dev: FastAPI + Next.js run natively (uvicorn / npm) against the SAME
# managed services as prod — no local Postgres, no SSH tunnel. Use a Neon `dev`
# branch so local work doesn't touch prod data.
#   make backend-dev   # sources this file, runs uvicorn on :8000
#   make frontend-dev  # Next.js on :3000

# --- Postgres: Neon dev branch ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB
DB_SSL=require

# --- Embeddings: Voyage ---
EMBED_BASE_URL=https://api.voyageai.com/v1
EMBED_MODEL=voyage-3.5
EMBED_API_KEY=
EMBED_DIM=1024

# --- LLM + Whisper: Groq ---
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=qwen/qwen3-32b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=120

# --- Document pipeline ---
DOCS_CHUNK_SIZE=800
DOCS_CHUNK_OVERLAP=100
DOCS_TOP_K=5
MAX_AGENT_ITERATIONS=8
LOG_LEVEL=DEBUG

# Warn-only locally so a missing secret logs instead of 403.
INTERNAL_SECRET=__FILL_OPENSSL_RAND_HEX_32__
ENFORCE_INTERNAL_SECRET=False
