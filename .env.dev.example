# Local dev: Postgres in compose; FastAPI + Next.js run natively on the host.
# TEI + Ollama run on a remote host and are reached over an SSH tunnel:
#   make tunnel    # opens local 127.0.0.1:8080 -> remote TEI, 127.0.0.1:11434 -> remote Ollama

# --- Postgres (in compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localdev
POSTGRES_DB=kb
POSTGRES_HOST_BIND=127.0.0.1:5432:5432

# --- App connection string (used by native uvicorn locally) ---
DATABASE_URL=postgresql+asyncpg://postgres:localdev@127.0.0.1:5432/kb

# --- Embeddings (TEI on remote host, reached via SSH tunnel) ---
EMBED_BASE_URL=http://127.0.0.1:8080/v1
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# --- LLM (Ollama on remote host, reached via SSH tunnel) ---
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=ollama

# --- Document pipeline ---
DOCS_CHUNK_SIZE=800
DOCS_CHUNK_OVERLAP=100
DOCS_TOP_K=5

MAX_AGENT_ITERATIONS=8
LOG_LEVEL=DEBUG
