# Managed-services stack. Copy to `.env.dev` (local uvicorn) or `.env` (VPS compose).

# --- Postgres: Neon (managed) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB
DB_SSL=require

# --- Embeddings: Voyage ---
EMBED_BASE_URL=https://api.voyageai.com/v1
EMBED_MODEL=voyage-3.5
EMBED_API_KEY=
EMBED_DIM=1024

# --- LLM + Whisper: Groq ---
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=qwen/qwen3-32b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=120

# --- Document pipeline ---
DOCS_CHUNK_SIZE=800
DOCS_CHUNK_OVERLAP=100
DOCS_TOP_K=5
MAX_AGENT_ITERATIONS=8
LOG_LEVEL=INFO

# --- BFF shared secret (must match Vercel INTERNAL_SECRET). openssl rand -hex 32 ---
INTERNAL_SECRET=__FILL_OPENSSL_RAND_HEX_32__
ENFORCE_INTERNAL_SECRET=True
