DATABASE_URL=postgresql+asyncpg://postgres:localdev@localhost:5432/kb

EMBED_BASE_URL=http://localhost:8080/v1
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=ollama

DOCS_CHUNK_SIZE=800
DOCS_CHUNK_OVERLAP=100
DOCS_TOP_K=5

MAX_AGENT_ITERATIONS=8
LOG_LEVEL=INFO

# Whisper speech-to-text (faster-whisper, in-process). cpu+int8 works
# everywhere; cuda+float16 if a GPU is available.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
