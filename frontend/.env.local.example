# Local Next.js dev — `next dev` reads .env.local automatically.
# Copy this file to .env.local and fill in real values.
# Server-only variables (NO NEXT_PUBLIC_ prefix) — never reach the browser bundle.

# Where the BFF server-side fetches go. Mac dev → local uvicorn on :8000.
FASTAPI_INTERNAL_URL=http://localhost:8000

# Shared secret with FastAPI. Must match agent-platform/.env.dev's INTERNAL_SECRET.
INTERNAL_SECRET=__FILL_MATCH_BACKEND_ENV_DEV__

# --- Prod-only (set in Vercel project env, NOT here) ---
# FASTAPI_INTERNAL_URL=https://api.askatlas.info
