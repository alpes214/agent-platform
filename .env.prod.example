# Production deployment: full stack in compose. TEI + Ollama run on the host (out-of-compose).
# Containers reach them through host.docker.internal:host-gateway.

# --- Postgres (in compose; NOT bound to a host port in prod) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__FILL_STRONG_RANDOM__
POSTGRES_DB=kb
# Intentionally omit POSTGRES_HOST_BIND.

# --- App connection string (used inside the FastAPI container, hostname=postgres) ---
# Not strictly needed here; compose composes this from POSTGRES_* automatically.
# Keeping for symmetry with .env.dev.example:
DATABASE_URL=postgresql+asyncpg://postgres:__FILL_STRONG_RANDOM__@postgres:5432/kb

# --- Embeddings (TEI on the host) ---
EMBED_BASE_URL=http://host.docker.internal:8080/v1
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# --- LLM (Ollama on the host) ---
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=ollama

# --- Document pipeline ---
DOCS_CHUNK_SIZE=800
DOCS_CHUNK_OVERLAP=100
DOCS_TOP_K=5

MAX_AGENT_ITERATIONS=8
LOG_LEVEL=INFO

# Phase 7 BFF — shared secret between Vercel BFF and this FastAPI. MUST match
# the INTERNAL_SECRET set in Vercel project env. Generate with
# `openssl rand -hex 32`. Keep ENFORCE_INTERNAL_SECRET=False during the
# migration window; flip to True after all browser fetches are routed through
# the BFF (Phase 7 step 10).
INTERNAL_SECRET=__FILL_OPENSSL_RAND_HEX_32__
ENFORCE_INTERNAL_SECRET=False

# --- Cloudflare Tunnel ---
# From Phase C.4: `cloudflared tunnel token knowledge-search` on the server
CLOUDFLARED_TUNNEL_TOKEN=__FILL_FROM_CLOUDFLARED__
